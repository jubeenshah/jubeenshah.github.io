---
layout: null
---
{
  {%- for post in site.posts -%}
  "{{ post.url | relative_url }}": {
    "title": {{ post.title | jsonify }},
    "date": "{{ post.date | date: '%b %d, %Y' }}",
    "category": "{{ post.category }}",
    "subcategory": "{{ post.subcategory }}",
    "excerpt": {{ post.content | strip_html | truncatewords: 40 | jsonify }},
    "words": {{ post.content | number_of_words }},
    "nsfw": {{ post.nsfw | default: false }}
  },
  {%- endfor -%}
  {%- for page in site.pages -%}
  {%- if page.title and page.url != "/" -%}
  "{{ page.url | relative_url }}": {
    "title": {{ page.title | jsonify }},
    "date": "",
    "category": "page",
    "subcategory": "",
    "excerpt": {{ page.content | strip_html | truncatewords: 40 | jsonify }},
    "words": {{ page.content | number_of_words }},
    "nsfw": false
  },
  {%- endif -%}
  {%- endfor -%}
  "_": null
}
