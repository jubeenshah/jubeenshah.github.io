---
layout: null
---
{%- assign total = 0 -%}
{%- for group in site.data.achievements -%}
  {%- assign total = total | plus: group.items.size -%}
{%- endfor -%}
{
  "description": "Verified achievements of Jubeen Shah. Every item's url is a public proof page. Rendered at {{ site.url }}/about/",
  "total": {{ total }},
  "groups": [
    {%- for group in site.data.achievements -%}
    {%- if group.items and group.items.size > 0 -%}
    {
      "key": {{ group.key | jsonify }},
      "label": {{ group.label | jsonify }},
      "count": {{ group.items.size }},
      "items": [
        {%- for item in group.items -%}
        {
          "name": {{ item.name | jsonify }},
          "desc": {{ item.desc | default: nil | jsonify }},
          "url": {{ item.url | absolute_url | jsonify }},
          "image": {% if item.image %}{{ item.image | absolute_url | jsonify }}{% else %}null{% endif %}
        }{% unless forloop.last %},{% endunless %}
        {%- endfor %}
      ]
    },
    {%- endif -%}
    {%- endfor -%}
    null
  ]
}
